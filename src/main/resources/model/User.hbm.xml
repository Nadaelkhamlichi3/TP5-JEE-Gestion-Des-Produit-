<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">

<hibernate-mapping package="model">
    <class name="User" table="users">
        <id name="id" column="id" type="long">
            <generator class="identity"/>
        </id>

        <property name="username" column="username" type="string" not-null="true" unique="true" length="50"/>
        <property name="password" column="password" type="string" not-null="true" length="255"/>

        <many-to-one name="role" class="model.Role" column="role_id" not-null="true"/>
    </class>
</hibernate-mapping>